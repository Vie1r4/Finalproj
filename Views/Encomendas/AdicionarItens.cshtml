@model Finalproj.Models.EncomendaCriarViewModel
@using Finalproj.Models
@{
    ViewData["Title"] = "Catálogo – adicionar produtos à encomenda";
    var clienteNome = ViewData["ClienteNome"] as string ?? "";
    var clienteId = ViewData["ClienteId"] as int? ?? Model.ClienteId;
    var pesquisa = ViewData["Pesquisa"] as string ?? "";
    var classificacao = ViewData["Classificacao"] as string ?? "";
    var grupoCompatibilidade = ViewData["GrupoCompatibilidade"] as string ?? "";
    var filtroTecnico = ViewData["FiltroTecnico"] as string ?? "";
    var calibre = ViewData["Calibre"] as string ?? "";
    var produtosFiltrados = ViewData["ProdutosFiltrados"] as List<Produto> ?? new List<Produto>();
    var itensRascunho = Model.Itens ?? new List<EncomendaItemCriarViewModel>();
}
<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-1">Nova encomenda</h1>
        <p class="text-muted mb-0">
            Cliente: <strong>@clienteNome</strong>
            <a asp-action="Create" class="btn btn-sm btn-outline-secondary ms-2">Alterar cliente</a>
        </p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Voltar à lista</a>
</div>

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm">
        @TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}
@if (TempData["ItemAdicionado"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm">
        @TempData["ItemAdicionado"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}
@if (TempData["ErroStock"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm">
        @TempData["ErroStock"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white border-bottom py-3">
        <h5 class="mb-0 fw-semibold">Procurar no catálogo</h5>
    </div>
    <div class="card-body">
        <form method="get" asp-action="AdicionarItens" class="row g-3 align-items-end">
            <input type="hidden" name="clienteId" value="@clienteId" />
            <div class="col-12 col-md-3">
                <label class="form-label small text-muted">Pesquisar por nome</label>
                <input type="text" name="pesquisa" value="@pesquisa" class="form-control" placeholder="Nome do produto..." />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted">Classificação de risco</label>
                <select name="classificacao" class="form-select">
                    <option value="">— Todas —</option>
                    @foreach (var c in ConstantesCatalogo.ClassificacoesRisco)
                    {
                        <option value="@c" selected="@(classificacao == c)">@ConstantesCatalogo.TextoClassificacao(c)</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted">Grupo ADR</label>
                <select name="grupoCompatibilidade" class="form-select">
                    <option value="">— Todos —</option>
                    @foreach (var g in ConstantesCatalogo.GruposCompatibilidade)
                    {
                        <option value="@g.Value" selected="@(grupoCompatibilidade == g.Value)">@g.Value</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted">Filtro técnico</label>
                <select name="filtroTecnico" class="form-select">
                    <option value="">— Todos —</option>
                    @foreach (var f in ConstantesCatalogo.FiltrosTecnicos)
                    {
                        <option value="@f.Value" selected="@(filtroTecnico == f.Value)">@f.Text</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted">Calibre</label>
                <select name="calibre" class="form-select">
                    <option value="">— Todos —</option>
                    @foreach (var cal in ConstantesCatalogo.Calibres)
                    {
                        <option value="@cal.Value" selected="@(calibre == cal.Value)">@cal.Text</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-1">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
        </form>
        <div class="mt-2">
            <a asp-action="AdicionarItens" asp-route-clienteId="@clienteId" class="small text-muted">Limpar filtros</a>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-semibold">Selecionar artigo</h5>
            </div>
            <div class="card-body">
                <form asp-action="AdicionarItem" method="post" class="row g-3 align-items-end">
                    <input type="hidden" name="clienteId" value="@clienteId" />
                    <input type="hidden" name="pesquisa" value="@pesquisa" />
                    <input type="hidden" name="classificacao" value="@classificacao" />
                    <input type="hidden" name="grupoCompatibilidade" value="@grupoCompatibilidade" />
                    <input type="hidden" name="filtroTecnico" value="@filtroTecnico" />
                    <input type="hidden" name="calibre" value="@calibre" />
                    <div class="col-12 col-md-6">
                        <label class="form-label">Produto</label>
                        <select name="produtoId" class="form-select" required>
                            <option value="">— Escolher produto —</option>
                            @foreach (var p in produtosFiltrados)
                            {
                                <option value="@p.Id">@p.Nome</option>
                            }
                        </select>
                        @if (!produtosFiltrados.Any())
                        {
                            <small class="text-muted">Use os filtros acima para procurar produtos.</small>
                        }
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label">Quantidade</label>
                        <input type="number" name="quantidade" class="form-control" step="0.0001" min="0.0001" value="1" required />
                    </div>
                    <div class="col-12 col-md-3">
                        <button type="submit" class="btn btn-primary w-100">Adicionar à encomenda</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm border-0 border-primary">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0 fw-semibold">Itens da encomenda @(itensRascunho.Any() ? $"({itensRascunho.Count})" : "")</h5>
            </div>
            <div class="card-body">
                @if (itensRascunho.Any())
                {
                    <ul class="list-group list-group-flush mb-3">
                        @foreach (var item in itensRascunho)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 border-0 border-bottom">
                                <span>@item.ProdutoNome <strong class="ms-1">× @item.Quantidade.ToString("N2")</strong></span>
                                <form asp-action="RemoverItem" method="post" class="d-inline">
                                    <input type="hidden" name="clienteId" value="@clienteId" />
                                    <input type="hidden" name="produtoId" value="@item.ProdutoId" />
                                    <input type="hidden" name="pesquisa" value="@pesquisa" />
                                    <input type="hidden" name="classificacao" value="@classificacao" />
                                    <input type="hidden" name="grupoCompatibilidade" value="@grupoCompatibilidade" />
                                    <input type="hidden" name="filtroTecnico" value="@filtroTecnico" />
                                    <input type="hidden" name="calibre" value="@calibre" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Remover">×</button>
                                </form>
                            </li>
                        }
                    </ul>
                    <form asp-action="AdicionarItens" method="post">
                        <input type="hidden" name="clienteId" value="@clienteId" />
                        <div class="mb-3">
                            <label for="dataEntrega" class="form-label small">Data de entrega</label>
                            <input type="date" name="dataEntrega" id="dataEntrega" class="form-control form-control-sm" />
                        </div>
                        <div class="mb-3">
                            <label for="observacoes" class="form-label small">Observações</label>
                            <textarea name="observacoes" id="observacoes" class="form-control form-control-sm" rows="2" maxlength="2000" placeholder="Notas, morada de entrega, etc."></textarea>
                        </div>
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success w-100 py-2">Registar encomenda</button>
                    </form>
                }
                else
                {
                    <p class="text-muted small mb-0">Nenhum item adicionado. Use os filtros para procurar e adicione produtos acima.</p>
                }
            </div>
        </div>
    </div>
</div>
