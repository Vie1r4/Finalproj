@model IEnumerable<Finalproj.Models.PaiolComOcupacaoViewModel>

@{
    ViewData["Title"] = "Armazém";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Armazém</h1>
        <p class="text-muted mb-0">Clique no paiol para ver o conteúdo. Use Detalhes para informações do paiol.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Stock" class="btn btn-outline-primary">Stock</a>
        <a asp-action="Movimentos" class="btn btn-outline-secondary">Movimentos</a>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Gestao" class="btn btn-outline-primary">Gestão de Paióis</a>
        }
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Paiol.Nome)</th>
            <th>@Html.DisplayNameFor(model => model.Paiol.Localizacao)</th>
            <th>Perfil de Risco</th>
            <th>Teto de segurança (kg)</th>
            <th>Ocupação</th>
            <th>Estado</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var p = item.Paiol;
            var pct = item.PercentagemOcupacao;
            <tr>
                <td><a asp-action="Conteudo" asp-route-id="@p.Id">@Html.DisplayFor(m => p.Nome)</a></td>
                <td>@Html.DisplayFor(m => p.Localizacao)</td>
                <td>@p.PerfilRisco</td>
                <td>@Html.DisplayFor(m => p.LimiteMLE)</td>
                <td>
                    <span class="fw-medium">@item.MleAtual.ToString("N1")</span> / @p.LimiteMLE.ToString("N0") kg
                    <span class="text-muted">(@pct.ToString("N0")%)</span>
                </td>
                <td>@p.Estado</td>
                <td>
                    <a asp-action="Details" asp-route-id="@p.Id">Detalhes</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted">Não tem acesso a nenhum paiol. Contacte o administrador para obter permissões.</p>
}
