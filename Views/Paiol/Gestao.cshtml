@model IEnumerable<Finalproj.Models.PaiolComOcupacaoViewModel>

@{
    ViewData["Title"] = "Gestão de Paióis";
}

<h1>Gestão de Paióis</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Criar novo paiol</a>
    <a asp-controller="EntradaPaiol" asp-action="Registar" class="btn btn-success">Registar entrada no paiol</a>
    <a asp-action="Movimentos" asp-route-tipo="Entradas" class="btn btn-outline-secondary">Movimentos</a>
    <a asp-controller="Paiol" asp-action="Index" class="btn btn-outline-secondary">Voltar ao Armazém</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Paiol.Nome)</th>
            <th>@Html.DisplayNameFor(model => model.Paiol.Localizacao)</th>
            <th>@Html.DisplayNameFor(model => model.Paiol.LimiteMLE)</th>
            <th>Perfil de Risco</th>
            <th>Ocupação</th>
            <th>Estado</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var p = item.Paiol;
            var pct = item.PercentagemOcupacao;
            <tr>
                <td>@Html.DisplayFor(m => p.Nome)</td>
                <td>@Html.DisplayFor(m => p.Localizacao)</td>
                <td>@Html.DisplayFor(m => p.LimiteMLE) kg</td>
                <td>@p.PerfilRisco</td>
                <td>
                    <span class="fw-medium">@item.MleAtual.ToString("N1")</span> / @p.LimiteMLE.ToString("N0") kg
                    <span class="text-muted">(@pct.ToString("N0")%)</span>
                </td>
                <td>@p.Estado</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@p.Id">Editar</a> |
                    <a asp-action="Details" asp-route-id="@p.Id">Detalhes</a> |
                    <a asp-action="Delete" asp-route-id="@p.Id">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
