@model Finalproj.Models.Paiol
@{
    ViewData["Title"] = "Detalhes do Paiol";
}

<h1 class="mb-3">Detalhes do Paiol</h1>

<div class="card mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0">Identificação</h5>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Nome)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Nome)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Localizacao)</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model?.Localizacao) ? "—" : Model.Localizacao)</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">@Model?.Estado</dd>

            <dt class="col-sm-3">Cargos com acesso</dt>
            <dd class="col-sm-9">@(ViewData["CargosAcesso"] is IList<string> cargos && cargos.Any() ? string.Join(", ", cargos) : "Nenhum cargo definido")</dd>
        </dl>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0">Licença e capacidade</h5>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">N.º licença</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model?.NumeroLicenca) ? "—" : Model.NumeroLicenca)</dd>

            <dt class="col-sm-3">Validade da licença</dt>
            <dd class="col-sm-9">@(Model?.DataValidadeLicenca.HasValue == true ? Model.DataValidadeLicenca.Value.ToString("dd/MM/yyyy") : "—")</dd>

            <dt class="col-sm-3">Perfil de risco</dt>
            <dd class="col-sm-9">@Model?.PerfilRisco</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.LimiteMLE)</dt>
            <dd class="col-sm-9">@Model?.LimiteMLE.ToString("N2") kg (Teto de Segurança NEM)</dd>

            <dt class="col-sm-3">NEM atual (kg)</dt>
            <dd class="col-sm-9">@(ViewData["NEMAtual"] is decimal nem ? nem.ToString("N2") : "0,00") / @(Model?.LimiteMLE.ToString("N2") ?? "—") (capacidade máxima licenciada)</dd>
        </dl>
    </div>
</div>

@if (ViewData["Carga"] is IEnumerable<Finalproj.Models.CargaPaiolItem> carga && carga.Any())
{
    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Carga no paiol</h5>
        </div>
        <div class="card-body">
            <p class="text-muted small mb-3">Ocupação = soma da NEM de todos os produtos (legislação portuguesa)</p>
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Produto</th>
                            <th>Divisão de risco</th>
                            <th>Quantidade</th>
                            <th>NEM (kg)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var x in carga)
                        {
                            <tr>
                                <td>@x.ProdutoNome</td>
                                <td>@(string.IsNullOrEmpty(x.Divisao) ? "—" : x.Divisao)</td>
                                <td>@x.Quantidade.ToString("N2")</td>
                                <td>@x.NEMTotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (Model?.DocumentosExtras?.Any() == true)
{
    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Documentação</h5>
        </div>
        <div class="card-body">
            <ul class="list-unstyled mb-0">
                @foreach (var doc in Model.DocumentosExtras)
                {
                    <li class="mb-2">
                        <a asp-action="Download" asp-route-id="@Model.Id" asp-route-extraId="@doc.Id" target="_blank" class="btn btn-outline-primary btn-sm">@(string.IsNullOrWhiteSpace(doc.Nome) ? "Documento" : doc.Nome)</a>
                    </li>
                }
            </ul>
        </div>
    </div>
}

<div class="d-flex gap-2">
    <a asp-action="Conteudo" asp-route-id="@Model?.Id" class="btn btn-outline-primary">Ver conteúdo do paiol</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Voltar ao Armazém</a>
</div>
