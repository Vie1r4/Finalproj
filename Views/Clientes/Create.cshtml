@model Finalproj.Models.Cliente
@{
    ViewData["Title"] = "Adicionar Cliente";
}

<h1 class="mb-3">Adicionar Cliente</h1>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="mb-3">
                <label asp-for="Nome" class="form-label">Nome</label> <span class="text-danger">*</span>
                <input asp-for="Nome" class="form-control" placeholder="Nome do cliente" />
                <span asp-validation-for="Nome" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="exemplo@email.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Telefone" class="form-label">Telefone</label>
                <input asp-for="Telefone" class="form-control" placeholder="Telefone" />
                <span asp-validation-for="Telefone" class="text-danger small"></span>
            </div>
            <div class="mb-0">
                <label asp-for="Notas" class="form-label">Observações</label> <span class="text-muted small">(opcional)</span>
                <textarea asp-for="Notas" class="form-control" rows="3" placeholder="Notas ou observações sobre o cliente"></textarea>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
