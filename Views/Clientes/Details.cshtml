@model Finalproj.Models.Cliente
@using Finalproj.Models
@{
    ViewData["Title"] = "Detalhes do cliente";
    var encomendasAtivas = ViewData["EncomendasAtivas"] as IList<Encomenda> ?? new List<Encomenda>();
    var encomendasHistorico = ViewData["EncomendasHistorico"] as IList<Encomenda> ?? new List<Encomenda>();
    var historicoPagina = (int)(ViewData["HistoricoPagina"] ?? 1);
    var totalPaginasHistorico = (int)(ViewData["TotalPaginasHistorico"] ?? 1);
    var totalHistorico = (int)(ViewData["TotalHistorico"] ?? 0);
}

<h1 class="mb-2">@Model.Nome</h1>
<p class="text-muted mb-4">Ficha do cliente</p>

@if (TempData["ClienteEditado"] as bool? == true)
{
    <div class="alert alert-success alert-dismissible fade show">
        Alterações guardadas.
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Identificação e contacto</h5>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-primary">Editar</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
        </div>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 col-md-2">Nome</dt>
            <dd class="col-sm-9 col-md-10">@Model.Nome</dd>
            <dt class="col-sm-3 col-md-2">Tipo</dt>
            <dd class="col-sm-9 col-md-10">@(Model.TipoCliente ?? "—")</dd>
            <dt class="col-sm-3 col-md-2">NIF</dt>
            <dd class="col-sm-9 col-md-10">@(Model.NIF ?? "—")</dd>
            <dt class="col-sm-3 col-md-2">Email</dt>
            <dd class="col-sm-9 col-md-10">@(Model.Email ?? "—")</dd>
            <dt class="col-sm-3 col-md-2">Telefone</dt>
            <dd class="col-sm-9 col-md-10">@(Model.Telefone ?? "—")</dd>
            <dt class="col-sm-3 col-md-2">Morada</dt>
            <dd class="col-sm-9 col-md-10">@(Model.Morada ?? "—")</dd>
            @if (!string.IsNullOrWhiteSpace(Model.Notas))
            {
                <dt class="col-sm-3 col-md-2">Observações</dt>
                <dd class="col-sm-9 col-md-10">@Model.Notas</dd>
            }
        </dl>
    </div>
</div>

@if (Model.DocumentosExtras?.Any() == true)
{
    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Documentação</h5>
        </div>
        <div class="card-body">
            <ul class="list-unstyled mb-0">
                @foreach (var ext in Model.DocumentosExtras)
                {
                    <li class="mb-1">
                        <a asp-action="Download" asp-route-id="@Model.Id" asp-route-extraId="@ext.Id" target="_blank" class="btn btn-sm btn-outline-success">@(string.IsNullOrWhiteSpace(ext.Nome) ? "Ver documento" : ext.Nome)</a>
                    </li>
                }
            </ul>
        </div>
    </div>
}

<div class="card mb-4 shadow-sm border-0">
    <div class="card-header bg-white border-bottom py-3 px-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
            <ul class="nav nav-tabs card-header-tabs border-0 h5 mb-0 align-items-center gap-2" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-semibold text-dark border-0 pb-2 pt-0 px-0 me-3" id="tab-ativas" data-bs-toggle="tab" data-bs-target="#ativas" type="button" role="tab" aria-controls="ativas" aria-selected="true">
                        <span class="me-1">🕐</span> Encomendas ativas
                        @if (encomendasAtivas.Any())
                        {
                            <span class="badge rounded-pill bg-dark ms-1">@encomendasAtivas.Count</span>
                        }
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-semibold text-secondary border-0 pb-2 pt-0 px-0" id="tab-historico" data-bs-toggle="tab" data-bs-target="#historico" type="button" role="tab" aria-controls="historico" aria-selected="false">
                        <span class="me-1">📁</span> Histórico
                        @if (totalHistorico > 0)
                        {
                            <span class="badge rounded-pill bg-secondary ms-1">@totalHistorico</span>
                        }
                    </button>
                </li>
            </ul>
            <a asp-controller="Encomendas" asp-action="Create" asp-route-clienteId="@Model.Id" class="btn btn-sm btn-primary">Nova encomenda</a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="tab-content">
            <div class="tab-pane fade show active" id="ativas" role="tabpanel" aria-labelledby="tab-ativas">
                @if (encomendasAtivas.Any())
                {
                    <p class="px-4 pt-3 mb-0 fw-semibold text-dark">
                        <span class="text-warning me-1">⚠</span> Encomendas que requerem a tua atenção
                    </p>
                    <div class="table-responsive px-4 pb-4">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Encomenda</th>
                                    <th>Estado</th>
                                    <th>Data</th>
                                    <th class="text-end">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var e in encomendasAtivas)
                                {
                                    var badgeClass = e.Estado == ConstantesEncomenda.PENDENTE ? "bg-warning text-dark" : e.Estado == ConstantesEncomenda.ACEITE ? "bg-info" : "bg-primary";
                                    var numProdutos = e.Itens?.Count ?? 0;
                                    var primeiroProduto = e.Itens?.FirstOrDefault()?.Produto?.Nome;
                                    var resumo = numProdutos == 0 ? "Sem itens" : numProdutos == 1 ? (primeiroProduto ?? "1 produto") : numProdutos + " produtos";
                                    <tr>
                                        <td>
                                            <div class="fw-semibold text-dark">Encomenda #@e.Id</div>
                                            <div class="small text-muted">@resumo</div>
                                        </td>
                                        <td><span class="badge rounded-pill @badgeClass">@e.Estado</span></td>
                                        <td class="text-nowrap">@e.DataCriacao.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="text-end">
                                            <div class="d-flex flex-wrap gap-1 justify-content-end">
                                                <a asp-controller="Encomendas" asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-dark">Ver detalhes</a>
                                                @if (e.Estado == ConstantesEncomenda.PENDENTE && User.IsInRole("Admin"))
                                                {
                                                    <a asp-controller="Encomendas" asp-action="Aceitar" asp-route-id="@e.Id" class="btn btn-sm btn-dark">Aceitar</a>
                                                    <a asp-controller="Encomendas" asp-action="Rejeitar" asp-route-id="@e.Id" class="btn btn-sm btn-outline-danger">Rejeitar</a>
                                                }
                                                @if (e.Estado == ConstantesEncomenda.ACEITE && User.IsInRole("Admin"))
                                                {
                                                    <a asp-controller="Encomendas" asp-action="Preparar" asp-route-id="@e.Id" class="btn btn-sm btn-dark">Preparar</a>
                                                }
                                                @if (e.Estado == ConstantesEncomenda.EM_PREPARACAO && User.IsInRole("Admin"))
                                                {
                                                    <a asp-controller="Encomendas" asp-action="Concluir" asp-route-id="@e.Id" class="btn btn-sm btn-dark">Concluir</a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 px-4">
                        <p class="text-muted mb-3">Este cliente ainda não tem encomendas ativas.</p>
                        <a asp-controller="Encomendas" asp-action="Create" asp-route-clienteId="@Model.Id" class="btn btn-outline-primary">Criar encomenda</a>
                    </div>
                }
            </div>
            <div class="tab-pane fade" id="historico" role="tabpanel" aria-labelledby="tab-historico">
                @if (encomendasHistorico.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var e in encomendasHistorico)
                        {
                            var badgeClass = e.Estado == ConstantesEncomenda.CONCLUIDA ? "bg-success" : "bg-danger";
                            var dataTexto = e.DataConclusao?.ToString("dd/MM/yyyy HH:mm") ?? e.DataCriacao.ToString("dd/MM/yyyy HH:mm");
                            <a asp-controller="Encomendas" asp-action="Details" asp-route-id="@e.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 px-4 border-0 border-bottom">
                                <div class="d-flex align-items-center gap-3">
                                    <span class="fw-semibold text-dark">Encomenda #@e.Id</span>
                                    <span class="badge rounded-pill @badgeClass px-2">@e.Estado</span>
                                    <span class="text-muted small">@dataTexto</span>
                                </div>
                                <span class="text-primary small fw-medium">Ver detalhes →</span>
                            </a>
                        }
                    </div>
                    @if (totalPaginasHistorico > 1)
                    {
                        <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top bg-light">
                            <span class="text-muted small">Página @historicoPagina de @totalPaginasHistorico · @totalHistorico encomenda(s) no total</span>
                            <nav aria-label="Paginação do histórico">
                                <ul class="pagination pagination-sm mb-0 gap-1">
                                    <li class="page-item @(historicoPagina <= 1 ? "disabled" : "")">
                                        <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-historicoPagina="@(historicoPagina - 1)">Anterior</a>
                                    </li>
                                    <li class="page-item @(historicoPagina >= totalPaginasHistorico ? "disabled" : "")">
                                        <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-historicoPagina="@(historicoPagina + 1)">Seguinte</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 px-4">
                        <p class="text-muted mb-0">Ainda não há encomendas concluídas ou rejeitadas.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div>
    <a asp-action="Index" class="btn btn-outline-secondary">Voltar à lista</a>
</div>
