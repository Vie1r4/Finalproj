@model IEnumerable<Finalproj.Models.UtilizadorComRolesViewModel>
@{
    ViewData["Title"] = "Gerir utilizadores";
}

<h1 class="mb-4">Gerir utilizadores</h1>

<p>
    <a asp-action="Index" class="btn btn-outline-secondary">← Voltar ao painel</a>
</p>

@if (TempData["Sucesso"] is string sucessoMsg)
{
    <div class="alert alert-success">@sucessoMsg</div>
}
@if (TempData["Erro"] is string erroMsg)
{
    <div class="alert alert-danger">@erroMsg</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nome de utilizador</th>
            <th>Email</th>
            <th>Cargos</th>
            <th>Funcionário associado</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.UserName</td>
                <td>@u.Email</td>
                <td>
                    @if (u.Roles.Count > 0)
                    {
                        @string.Join(", ", u.Roles)
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(u.FuncionarioAssociadoNome))
                    {
                        <span class="text-success">@u.FuncionarioAssociadoNome</span>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
                <td>
                    <a asp-action="EditarUtilizador" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                    <form asp-action="EliminarUtilizador" asp-route-id="@u.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Tem a certeza que pretende eliminar este utilizador?');">
                            Eliminar
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
